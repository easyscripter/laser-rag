# ---------- Database (Postgres) ----------
POSTGRES_USER=laserrag
POSTGRES_PASSWORD=laserrag
POSTGRES_DB=laserrag

# ---------- Ports (host) ----------
API_PORT=8000
FRONTEND_PORT=5173

# ---------- Backend: app ----------
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_JSON=false
CORS_ORIGINS=["http://localhost:5173"]

# ---------- Backend: LLM (OpenAI-compatible endpoint) — spec §9 ----------
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-changeme
MODEL_FAST=gpt-4o-mini
MODEL_LONG_CTX=gpt-4o-mini
MODEL_FALLBACK=gpt-4o-mini

# ---------- Backend: embeddings (local) ----------
EMBED_MODEL=all-MiniLM-L6-v2

# ---------- Backend: infrastructure (service names = compose hostnames) ----------
DATABASE_URL=postgresql+asyncpg://laserrag:laserrag@postgres:5432/laserrag
CHROMA_HOST=chromadb
CHROMA_PORT=8000
REDIS_URL=redis://redis:6379/0

# ---------- Backend: auth ----------
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=7

# ---------- Backend: chat & uploads ----------
CHAT_HISTORY_WINDOW=8
MAX_UPLOAD_MB=50
DEFAULT_TENANT_ID=default

# ---------- Frontend (build-time, baked by Vite via build args) ----------
VITE_API_BASE_URL=http://localhost:8000/api/v1
